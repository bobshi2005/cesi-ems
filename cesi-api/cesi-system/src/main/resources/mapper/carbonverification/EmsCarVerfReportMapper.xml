<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.cesi.carbonverification.mapper.EmsCarVerfReportMapper">

    <resultMap type="com.cesi.carbonverification.domain.EmsCarVerfReport" id="ReportResult">
        <result property="id"               column="id"/>
        <result property="reportName"       column="report_name"/>
        <result property="reportYear"       column="report_year"/>
        <result property="orgUnit"          column="org_unit"/>
        <result property="standard"         column="standard"/>
        <result property="templateType"     column="template_type"/>
        <result property="totalEmission"    column="total_emission"/>
        <result property="dataCompleteness" column="data_completeness"/>
        <result property="reportVersion"    column="report_version"/>
        <result property="filePath"         column="file_path"/>
        <result property="status"           column="status"/>
        <result property="generateTime"     column="generate_time"/>
        <result property="createBy"         column="create_by"/>
        <result property="createTime"       column="create_time"/>
        <result property="updateBy"         column="update_by"/>
        <result property="updateTime"       column="update_time"/>
        <result property="remark"           column="remark"/>
    </resultMap>

    <select id="selectPage" resultMap="ReportResult">
        SELECT id, report_name, report_year, org_unit, standard, template_type,
               total_emission, data_completeness, report_version, file_path, status,
               generate_time, create_by, create_time, update_by, update_time, remark
        FROM ems_carbon_verification_report
        <where>
            <if test="reportYear != null">AND report_year = #{reportYear}</if>
            <if test="orgUnit != null and orgUnit != ''">AND org_unit = #{orgUnit}</if>
        </where>
        ORDER BY create_time DESC
    </select>

</mapper>
