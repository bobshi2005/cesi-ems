<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.cesi.pcf.mapper.EmspcfEmissionFactorMapper">

    <resultMap type="com.cesi.pcf.domain.EmspcfEmissionFactor" id="FactorResult">
        <result property="id"              column="id"/>
        <result property="factorName"      column="factor_name"/>
        <result property="specType"        column="spec_type"/>
        <result property="factorCategory"  column="factor_category"/>
        <result property="emissionFactor"  column="emission_factor"/>
        <result property="factorUnit"      column="factor_unit"/>
        <result property="dataSource"      column="data_source"/>
        <result property="referenceYear"   column="reference_year"/>
        <result property="applicableScope" column="applicable_scope"/>
        <result property="isRecycled"      column="is_recycled"/>
        <result property="isBuiltin"       column="is_builtin"/>
        <result property="status"          column="status"/>
        <result property="remark"          column="remark"/>
        <result property="createBy"        column="create_by"/>
        <result property="createTime"      column="create_time"/>
        <result property="updateBy"        column="update_by"/>
        <result property="updateTime"      column="update_time"/>
    </resultMap>

    <select id="selectByCategory" resultMap="FactorResult">
        SELECT * FROM ems_pcf_emission_factor
        WHERE factor_category = #{factorCategory}
        ORDER BY is_builtin DESC, id ASC
    </select>

</mapper>
