<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.cesi.pcf.mapper.EmspcfGreenCertMapper">

    <resultMap type="com.cesi.pcf.domain.EmspcfGreenCert" id="GreenCertResult">
        <result property="id"                column="id"/>
        <result property="productId"         column="product_id"/>
        <result property="year"              column="year"/>
        <result property="certType"          column="cert_type"/>
        <result property="certNo"            column="cert_no"/>
        <result property="powerType"         column="power_type"/>
        <result property="purchaseVolume"    column="purchase_volume"/>
        <result property="convertedPower"    column="converted_power"/>
        <result property="emissionFactor"    column="emission_factor"/>
        <result property="emissionReduction" column="emission_reduction"/>
        <result property="validityStart"     column="validity_start"/>
        <result property="validityEnd"       column="validity_end"/>
        <result property="status"            column="status"/>
        <result property="remark"            column="remark"/>
        <result property="createBy"          column="create_by"/>
        <result property="createTime"        column="create_time"/>
        <result property="updateBy"          column="update_by"/>
        <result property="updateTime"        column="update_time"/>
    </resultMap>

    <select id="selectByProductAndYear" resultMap="GreenCertResult">
        SELECT * FROM ems_pcf_green_cert
        WHERE product_id = #{productId} AND year = #{year}
        ORDER BY id ASC
    </select>

    <select id="sumOffsetByProductAndYear" resultType="java.math.BigDecimal">
        SELECT COALESCE(SUM(emission_reduction), 0)
        FROM ems_pcf_green_cert
        WHERE product_id = #{productId} AND year = #{year}
    </select>

</mapper>
