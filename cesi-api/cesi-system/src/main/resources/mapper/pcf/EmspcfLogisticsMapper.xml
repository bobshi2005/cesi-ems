<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.cesi.pcf.mapper.EmspcfLogisticsMapper">

    <resultMap type="com.cesi.pcf.domain.EmspcfLogistics" id="LogisticsResult">
        <result property="id"              column="id"/>
        <result property="productId"       column="product_id"/>
        <result property="year"            column="year"/>
        <result property="materialName"    column="material_name"/>
        <result property="specModel"       column="spec_model"/>
        <result property="transportDist"   column="transport_dist"/>
        <result property="distUnit"        column="dist_unit"/>
        <result property="transportMode"   column="transport_mode"/>
        <result property="emissionFactor"  column="emission_factor"/>
        <result property="factorUnit"      column="factor_unit"/>
        <result property="carbonFootprint" column="carbon_footprint"/>
        <result property="carbonUnit"      column="carbon_unit"/>
        <result property="remark"          column="remark"/>
        <result property="createBy"        column="create_by"/>
        <result property="createTime"      column="create_time"/>
        <result property="updateBy"        column="update_by"/>
        <result property="updateTime"      column="update_time"/>
    </resultMap>

    <select id="selectByProductAndYear" resultMap="LogisticsResult">
        SELECT * FROM ems_pcf_logistics
        WHERE product_id = #{productId} AND year = #{year}
        ORDER BY id ASC
    </select>

    <select id="sumByProductAndYear" resultType="java.math.BigDecimal">
        SELECT COALESCE(SUM(carbon_footprint), 0)
        FROM ems_pcf_logistics
        WHERE product_id = #{productId} AND year = #{year}
    </select>

</mapper>
